from flask import Flask, render_template, request, redirect
from flask_sqlalchemy import SQLAlchemy
from datetime import datetime

app = Flask(__name__)

# MySQL connection
app.config['SQLALCHEMY_DATABASE_URI'] = 'mysql+pymysql://root:Vtu%4026790@localhost/todo_db'
app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False

db = SQLAlchemy(app)

# TABLE
class Task(db.Model):
    id = db.Column(db.Integer, primary_key=True)
    title = db.Column(db.String(200), nullable=False)
    deadline = db.Column(db.Date, nullable=False)

with app.app_context():
    db.create_all()

# SHOW DATA (any time you open browser)
@app.route('/')
def home():
    tasks = Task.query.order_by(Task.id.desc()).all()
    return render_template('index.html', tasks=tasks)

# SAVE DATA TO MYSQL (PERMANENT STORAGE)
@app.route('/add', methods=['POST'])
def add_task():
    title = request.form['title']
    deadline = request.form['deadline']

    deadline_date = datetime.strptime(deadline, '%Y-%m-%d').date()

    new_task = Task(title=title, deadline=deadline_date)

    db.session.add(new_task)
    db.session.commit()   # 🔥 THIS SAVES PERMANENTLY IN MYSQL

    return redirect('/')

if __name__ == '__main__':
    app.run(debug=True)